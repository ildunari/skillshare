import XCTest
import SwiftUI

final class HostingEmbeddingTests: XCTestCase {
    func testEmbedSwiftUIView() {
        let vc = UIViewController()
        let container = UIView(frame: CGRect(x: 0, y: 0, width: 300, height: 300))
        vc.view.addSubview(container)
        let host = vc.embed(Text("Hello"), in: container)
        XCTAssertNotNil(host.view.superview)
    }
}
