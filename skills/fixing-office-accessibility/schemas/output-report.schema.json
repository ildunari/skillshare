{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/fixing-office-accessibility/output-report.schema.json",
  "title": "Stage 4 Office Accessibility Remediation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "document_path",
    "executive_summary",
    "changes_committed",
    "changes_user_approved",
    "changes_user_declined",
    "items_deferred",
    "wcag_criteria_addressed",
    "validation_status",
    "file_backup_path"
  ],
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "document_path": {"type": "string", "minLength": 1},
    "manifest_path": {"type": "string"},
    "executive_summary": {"type": "string", "minLength": 1},
    "changes_committed": {
      "type": "array",
      "items": {"$ref": "#/$defs/change"}
    },
    "changes_user_approved": {
      "type": "array",
      "items": {"$ref": "#/$defs/decision"}
    },
    "changes_user_declined": {
      "type": "array",
      "items": {"$ref": "#/$defs/decision"}
    },
    "items_deferred": {
      "type": "array",
      "items": {"$ref": "#/$defs/deferred"}
    },
    "wcag_criteria_addressed": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "validation_status": {"$ref": "#/$defs/validation"},
    "file_backup_path": {"type": ["string", "null"]}
  },
  "$defs": {
    "change": {
      "type": "object",
      "additionalProperties": true,
      "required": ["finding_id", "rule_id", "location", "operation", "rationale", "wcag_criteria"],
      "properties": {
        "finding_id": {"type": "string"},
        "rule_id": {"type": "string"},
        "location": {"type": "string"},
        "operation": {"type": "string"},
        "before": {},
        "after": {},
        "officecli_commands": {"type": "array", "items": {"type": "object"}},
        "rationale": {"type": "string"},
        "wcag_criteria": {"type": "array", "items": {"type": "string"}},
        "decision_source": {"type": "string", "enum": ["agent_high_confidence", "user_approved", "default_policy", "no_op"]}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": true,
      "required": ["finding_id", "question", "user_response"],
      "properties": {
        "finding_id": {"type": "string"},
        "question": {"type": "string"},
        "user_response": {"type": "string"},
        "decision_at": {"type": "string", "format": "date-time"}
      }
    },
    "deferred": {
      "type": "object",
      "additionalProperties": true,
      "required": ["finding_id", "rule_id", "location", "reason"],
      "properties": {
        "finding_id": {"type": "string"},
        "rule_id": {"type": "string"},
        "location": {"type": "string"},
        "reason": {"type": "string"},
        "recommended_next_step": {"type": "string"}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["passed", "command"],
      "properties": {
        "passed": {"type": "boolean"},
        "command": {"type": "string"},
        "checked_at": {"type": "string", "format": "date-time"},
        "stdout": {"type": "string"},
        "stderr": {"type": "string"},
        "restored_from_backup": {"type": "boolean"}
      }
    }
  }
}
