{
  "version": "1.0",
  "description": "Renderable visual themes for pptx-master. A theme selects a palette+mode and defines typography scale and shape treatments.",
  "themes": [
    {
      "id": "atlas",
      "name": "Atlas",
      "palette": {
        "id": "consulting_blue",
        "mode": "light"
      },
      "typography": {
        "fonts": {
          "headline": {
            "family": "Arial",
            "weight": 700
          },
          "body": {
            "family": "Arial",
            "weight": 400
          }
        },
        "sizes_pt": {
          "h1": 40,
          "h2": 30,
          "body": 20,
          "caption": 14
        },
        "line_height": {
          "headline": 1.05,
          "body": 1.2
        }
      },
      "layout": {
        "density": "comfortable",
        "grid": {
          "margins_in": {
            "t": 0.7,
            "r": 0.7,
            "b": 0.7,
            "l": 0.7
          },
          "columns": 12,
          "gutter_in": 0.25
        }
      },
      "shapes": {
        "corner_radius": 14,
        "border_width": 1,
        "shadow": {
          "enabled": true,
          "opacity": 0.18,
          "blur_pt": 10,
          "offset_pt": {
            "x": 0,
            "y": 2
          }
        }
      },
      "cards": {
        "fill": "surface",
        "stroke": "border",
        "radius": 14
      },
      "charts": {
        "gridline_opacity": 0.25,
        "axis_label_size_pt": 14,
        "legend_size_pt": 12
      },
      "images": {
        "corner_radius": 12,
        "frame": {
          "enabled": false
        }
      },
      "icons": {
        "style": "outline",
        "stroke_width_pt": 1.8
      },
      "motion": {
        "transitions": {
          "slide": "fade",
          "duration_ms": 280
        },
        "builds": {
          "default_effect": "fade",
          "duration_ms": 320,
          "stagger_ms": 60
        }
      },
      "fills": {
        "heroGradient": {
          "type": "linear",
          "angle": 35,
          "stops": [
            {
              "pos": 0,
              "color": "primary",
              "alpha": 1
            },
            {
              "pos": 100,
              "color": "accent_1",
              "alpha": 1
            }
          ]
        }
      },
      "shadows": {
        "card": {
          "type": "outer",
          "color": "000000",
          "opacity": 0.18,
          "blur": 10,
          "angle": 90,
          "distance": 2
        },
        "pop": {
          "type": "outer",
          "color": "000000",
          "opacity": 0.26,
          "blur": 18,
          "angle": 90,
          "distance": 4
        }
      },
      "masters": {
        "DEFAULT": {
          "backgroundFill": "bg",
          "accentBar": {
            "enabled": true,
            "position": "top",
            "height": 0.04,
            "fill": "primary"
          },
          "slideNumber": {
            "enabled": true,
            "x": 12.55,
            "y": 7.16,
            "w": 0.7,
            "h": 0.28,
            "fontSize": 10,
            "color": "muted",
            "align": "right"
          }
        },
        "SECTION": {
          "backgroundFill": "heroGradient",
          "accentBar": {
            "enabled": true,
            "position": "bottom",
            "height": 0.08,
            "fill": "accent_1"
          },
          "slideNumber": {
            "enabled": false
          }
        },
        "COVER": {
          "backgroundFill": "bg",
          "accentBar": {
            "enabled": false
          },
          "slideNumber": {
            "enabled": false
          }
        }
      }
    },
